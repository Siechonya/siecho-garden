<script>
  (function() {
    // 防止重复添加按钮
    if (document.getElementById('sidebar-toggle-btn')) return;

    // 创建按钮
    const btn = document.createElement('button');
    btn.id = 'sidebar-toggle-btn';
    btn.innerHTML = '☰';
    btn.title = '隐藏左侧目录';
    btn.setAttribute('aria-label', 'Toggle Sidebar');
    btn.style.cssText = `
      position: fixed;
      top: 20px;
      left: 20px;
      z-index: 1000;
      background: #f0f0f0;
      border: none;
      font-size: 24px;
      cursor: pointer;
      padding: 5px 12px;
      border-radius: 4px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.2);
    `;

    // 点击时切换 body 类
    btn.onclick = () => {
      document.body.classList.toggle('hide-sidebar');
      const isHidden = document.body.classList.contains('hide-sidebar');
      btn.innerHTML = isHidden ? '✕' : '☰';
      btn.title = isHidden ? '显示左侧目录' : '隐藏左侧目录';
    };

    document.body.appendChild(btn);
  })();
</script>
