<!-- 自定义平滑滚动（修复特殊字符错误） -->
<script>
  (function() {
    // 自定义缓动滚动函数
    function smoothScrollTo(targetY, duration = 200) {
      const startY = window.scrollY;
      const distance = targetY - startY;
      const startTime = performance.now();

      function step(now) {
        const elapsed = now - startTime;
        const t = Math.min(1, elapsed / duration);
        // 缓动函数 easeInOutCubic
        const ease = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
        window.scrollTo(0, startY + distance * ease);
        if (t < 1) requestAnimationFrame(step);
      }

      requestAnimationFrame(step);
    }

    // 绑定所有 TOC 链接
    function initSmoothScroll() {
      // 根据你的 HTML 结构选择器
      const tocLinks = document.querySelectorAll('.toc a, .toc-container a, nav.toc a');
      if (!tocLinks.length) {
        console.warn('未找到 TOC 链接');
        return;
      }

      tocLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          const hash = this.getAttribute('href');
          if (!hash || hash === '#') return;

          // 使用 getElementById 避免特殊字符错误
          const targetElement = document.getElementById(hash.substring(1));
          if (targetElement) {
            e.preventDefault();
            const targetRect = targetElement.getBoundingClientRect();
            const absoluteTargetTop = targetRect.top + window.scrollY;

            // 如果你的页面有固定头部，可以设置偏移量，例如 80px
            // const offset = 80;
            // smoothScrollTo(absoluteTargetTop - offset, 500);
            smoothScrollTo(absoluteTargetTop, 500);
            
            // 更新地址栏 hash（不触发跳转）
            history.pushState(null, null, hash);
          } else {
            console.warn('未找到目标元素:', hash);
          }
        });
      });
      console.log(`✅ 自定义平滑滚动已绑定，共 ${tocLinks.length} 个链接`);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSmoothScroll);
    } else {
      initSmoothScroll();
    }
  })();
</script>
