<script>
(function() {
    // 自动检测页面的实际滚动容器
    function getScrollContainer() {
        // 优先查找 Obsidian 内容视图常用类
        const candidates = [
            '.markdown-preview-view',
            '.markdown-rendered',
            '.content',
            'main',
            'article'
        ];
        for (let sel of candidates) {
            const el = document.querySelector(sel);
            if (el) {
                const style = getComputedStyle(el);
                if (style.overflowY === 'auto' || style.overflowY === 'scroll') {
                    return el;
                }
            }
        }
        // 回退到 window
        return document.scrollingElement || document.documentElement;
    }

    // 平滑滚动函数（支持任意滚动容器）
    function smoothScrollTo(targetElement, duration = 500, offset = 0) {
        const scrollContainer = getScrollContainer();
        const isWindow = scrollContainer === document.scrollingElement ||
                         scrollContainer === document.documentElement ||
                         scrollContainer === document.body;

        let start, targetTop;
        if (isWindow) {
            start = window.scrollY;
            const rect = targetElement.getBoundingClientRect();
            targetTop = rect.top + start - offset;
        } else {
            start = scrollContainer.scrollTop;
            const containerRect = scrollContainer.getBoundingClientRect();
            const targetRect = targetElement.getBoundingClientRect();
            targetTop = targetRect.top - containerRect.top + start - offset;
        }

        const distance = targetTop - start;
        const startTime = performance.now();

        function step(now) {
            const elapsed = now - startTime;
            const t = Math.min(1, elapsed / duration);
            const ease = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
            const newTop = start + distance * ease;
            if (isWindow) window.scrollTo(0, newTop);
            else scrollContainer.scrollTop = newTop;
            if (t < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }

    function initSmoothScroll() {
        const tocLinks = document.querySelectorAll('.toc a, .toc-container a, nav.toc a');
        if (!tocLinks.length) {
            console.warn('未找到 TOC 链接');
            return;
        }

        tocLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                const hash = this.getAttribute('href');
                if (!hash || hash === '#') return;
                const targetElement = document.getElementById(hash.substring(1));
                if (targetElement) {
                    e.preventDefault();
                    // 如果你的页面有固定头部（如导航栏），可在此设置偏移量（单位 px）
                    const offset = 0;
                    smoothScrollTo(targetElement, 500, offset);
                    history.pushState(null, null, hash);
                } else {
                    console.warn('未找到目标元素:', hash);
                }
            });
        });
        console.log(`✅ 平滑滚动已绑定，共 ${tocLinks.length} 个链接，滚动容器:`, getScrollContainer());
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSmoothScroll);
    } else {
        initSmoothScroll();
    }
})();
</script>
